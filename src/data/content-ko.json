{
  "easy": [
    { "id": "ko-easy-001", "text": "산은 높고 바다는 넓다", "type": "poem", "meaning": null },
    { "id": "ko-easy-002", "text": "봄바람 살랑살랑 꽃이 피어요", "type": "poem", "meaning": null },
    { "id": "ko-easy-003", "text": "하늘은 파랗고 구름은 하얗다", "type": "poem", "meaning": null },
    { "id": "ko-easy-004", "text": "나비야 나비야 날아 와라", "type": "poem", "meaning": null },
    { "id": "ko-easy-005", "text": "별빛이 밤하늘에 떠요", "type": "poem", "meaning": null },
    { "id": "ko-easy-006", "text": "눈이 소복소복 내려요", "type": "poem", "meaning": null },
    { "id": "ko-easy-007", "text": "개나리꽃 노랗게 피었네", "type": "poem", "meaning": null },
    { "id": "ko-easy-008", "text": "참새가 짹짹짹 노래해요", "type": "poem", "meaning": null },
    { "id": "ko-easy-009", "text": "무지개가 일곱 빛깔 예뻐요", "type": "poem", "meaning": null },
    { "id": "ko-easy-010", "text": "달님이 환하게 웃어요", "type": "poem", "meaning": null },
    { "id": "ko-easy-011", "text": "바람이 솔솔솔 불어요", "type": "poem", "meaning": null },
    { "id": "ko-easy-012", "text": "물고기가 팔딱팔딱 뛰어요", "type": "poem", "meaning": null },
    { "id": "ko-easy-013", "text": "강아지가 멍멍멍 짖어요", "type": "poem", "meaning": null },
    { "id": "ko-easy-014", "text": "고양이가 야옹야옹 울어요", "type": "poem", "meaning": null },
    { "id": "ko-easy-015", "text": "토끼가 깡충깡충 뛰어요", "type": "poem", "meaning": null },
    { "id": "ko-easy-016", "text": "해님이 방긋방긋 웃어요", "type": "poem", "meaning": null },
    { "id": "ko-easy-017", "text": "빗방울이 톡톡톡 떨어져요", "type": "poem", "meaning": null },
    { "id": "ko-easy-018", "text": "꽃잎이 팔랑팔랑 날려요", "type": "poem", "meaning": null },
    { "id": "ko-easy-019", "text": "새들이 하늘 높이 날아요", "type": "poem", "meaning": null },
    { "id": "ko-easy-020", "text": "나뭇잎이 바람에 흔들려요", "type": "poem", "meaning": null },
    { "id": "ko-easy-021", "text": "눈꽃이 송이송이 내려요", "type": "poem", "meaning": null },
    { "id": "ko-easy-022", "text": "봄이 왔어요 꽃이 피었어요", "type": "poem", "meaning": null },
    { "id": "ko-easy-023", "text": "여름 하늘이 높고 파래요", "type": "poem", "meaning": null },
    { "id": "ko-easy-024", "text": "가을 단풍이 빨갛게 물들어요", "type": "poem", "meaning": null },
    { "id": "ko-easy-025", "text": "겨울 눈사람을 만들어요", "type": "poem", "meaning": null },
    { "id": "ko-easy-026", "text": "풀잎에 이슬이 반짝여요", "type": "poem", "meaning": null },
    { "id": "ko-easy-027", "text": "파란 하늘에 흰 구름이 떠요", "type": "poem", "meaning": null },
    { "id": "ko-easy-028", "text": "개구리가 폴짝폴짝 뛰어요", "type": "poem", "meaning": null },
    { "id": "ko-easy-029", "text": "별들이 반짝반짝 빛나요", "type": "poem", "meaning": null },
    { "id": "ko-easy-030", "text": "씨앗이 쑥쑥 자라나요", "type": "poem", "meaning": null },
    { "id": "ko-easy-031", "text": "노력은 배신하지 않는다", "type": "quote", "meaning": "열심히 노력하면 반드시 좋은 결과가 따른다는 뜻" },
    { "id": "ko-easy-032", "text": "꿈을 가진 자는 늙지 않는다", "type": "quote", "meaning": "꿈이 있으면 항상 젊고 활기차다는 뜻" },
    { "id": "ko-easy-033", "text": "작은 것도 감사히 여겨라", "type": "quote", "meaning": "사소한 것에도 감사하는 마음을 갖자는 뜻" },
    { "id": "ko-easy-034", "text": "친구는 제2의 자신이다", "type": "quote", "meaning": "진정한 친구는 나와 같은 소중한 존재라는 뜻" },
    { "id": "ko-easy-035", "text": "웃음은 최고의 약이다", "type": "quote", "meaning": "즐겁게 웃으면 몸과 마음이 건강해진다는 뜻" },
    { "id": "ko-easy-036", "text": "배움에는 끝이 없다", "type": "quote", "meaning": "평생 동안 계속 배우고 성장할 수 있다는 뜻" },
    { "id": "ko-easy-037", "text": "오늘 최선을 다하자", "type": "quote", "meaning": "지금 이 순간에 최선의 노력을 기울이자는 뜻" },
    { "id": "ko-easy-038", "text": "나눌수록 더 커진다", "type": "quote", "meaning": "좋은 것을 나누면 더 큰 기쁨이 생긴다는 뜻" },
    { "id": "ko-easy-039", "text": "용기란 두려움을 이기는 것", "type": "quote", "meaning": "두려워도 앞으로 나아가는 것이 진짜 용기라는 뜻" },
    { "id": "ko-easy-040", "text": "작은 실천이 큰 변화 만든다", "type": "quote", "meaning": "사소한 행동도 쌓이면 큰 변화를 가져온다는 뜻" },
    { "id": "ko-easy-041", "text": "실수는 성장의 발판이다", "type": "quote", "meaning": "실수를 통해 배우고 더 나은 사람이 될 수 있다는 뜻" },
    { "id": "ko-easy-042", "text": "한 걸음씩 나아가면 된다", "type": "quote", "meaning": "큰 목표도 작은 걸음부터 시작하면 이룰 수 있다는 뜻" },
    { "id": "ko-easy-043", "text": "마음이 따뜻한 사람이 되자", "type": "quote", "meaning": "다른 사람을 배려하고 따뜻하게 대하자는 뜻" },
    { "id": "ko-easy-044", "text": "긍정적으로 생각하면 달라진다", "type": "quote", "meaning": "좋은 마음으로 생각하면 결과도 좋아진다는 뜻" },
    { "id": "ko-easy-045", "text": "포기하지 않으면 길이 열린다", "type": "quote", "meaning": "끝까지 도전하면 반드시 방법을 찾게 된다는 뜻" },
    { "id": "ko-easy-046", "text": "사랑은 나눌수록 늘어난다", "type": "quote", "meaning": "사랑을 베풀수록 더 많은 사랑이 돌아온다는 뜻" },
    { "id": "ko-easy-047", "text": "정직한 사람이 가장 강하다", "type": "quote", "meaning": "거짓 없이 솔직한 사람이 오래 신뢰받는다는 뜻" },
    { "id": "ko-easy-048", "text": "호기심은 최고의 선생님", "type": "quote", "meaning": "궁금해하고 탐구하는 마음이 배움의 시작이라는 뜻" },
    { "id": "ko-easy-049", "text": "오늘 씨앗이 내일 꽃 핀다", "type": "quote", "meaning": "지금의 노력이 나중에 좋은 결과를 낳는다는 뜻" },
    { "id": "ko-easy-050", "text": "함께하면 더 멀리 갈 수 있다", "type": "quote", "meaning": "혼자보다 여럿이 협력하면 더 큰 일을 이룬다는 뜻" },
    { "id": "ko-easy-051", "text": "매일 조금씩 나아지자", "type": "quote", "meaning": "하루하루 조금씩 발전하면 크게 성장할 수 있다는 뜻" },
    { "id": "ko-easy-052", "text": "행복은 마음 안에 있다", "type": "quote", "meaning": "행복은 밖에서 찾는 게 아니라 내 마음에 달려있다는 뜻" },
    { "id": "ko-easy-053", "text": "배려는 아름다운 습관이다", "type": "quote", "meaning": "다른 사람을 생각하는 마음이 아름다운 덕목이라는 뜻" },
    { "id": "ko-easy-054", "text": "자신을 믿으면 길이 보인다", "type": "quote", "meaning": "스스로를 신뢰하는 마음이 가능성을 열어준다는 뜻" },
    { "id": "ko-easy-055", "text": "작은 친절이 세상을 바꾼다", "type": "quote", "meaning": "사소한 친절도 큰 변화의 시작이 될 수 있다는 뜻" },
    { "id": "ko-easy-056", "text": "모든 시작은 용감한 첫걸음", "type": "quote", "meaning": "무엇이든 시작하는 용기가 가장 중요하다는 뜻" },
    { "id": "ko-easy-057", "text": "칭찬은 고래도 춤추게 한다", "type": "quote", "meaning": "칭찬과 격려는 누구든 더 잘하게 만드는 힘이 있다는 뜻" },
    { "id": "ko-easy-058", "text": "웃는 얼굴엔 침 못 뱉는다", "type": "quote", "meaning": "활짝 웃는 사람에게는 나쁘게 대하기 어렵다는 뜻" },
    { "id": "ko-easy-059", "text": "고생 끝에 낙이 온다", "type": "quote", "meaning": "힘든 일을 이겨내면 반드시 즐거운 날이 온다는 뜻" },
    { "id": "ko-easy-060", "text": "꿈꾸는 자만이 이룰 수 있다", "type": "quote", "meaning": "목표를 품고 도전하는 사람이 결국 성공한다는 뜻" }
  ],
  "hard": [
    { "id": "ko-hard-001", "text": "가는 말이 고와야 오는 말이 곱다", "type": "proverb", "meaning": "자신이 남에게 좋게 대해야 남도 자신에게 좋게 대한다는 뜻" },
    { "id": "ko-hard-002", "text": "세 살 버릇 여든까지 간다", "type": "proverb", "meaning": "어릴 때 몸에 밴 버릇은 늙어서도 고치기 어렵다는 뜻" },
    { "id": "ko-hard-003", "text": "호랑이도 제 말 하면 온다", "type": "proverb", "meaning": "마침 이야기하던 사람이 나타날 때 쓰는 말" },
    { "id": "ko-hard-004", "text": "급할수록 돌아가라", "type": "proverb", "meaning": "서두를수록 실수하기 쉬우니 여유를 갖고 차근차근 하라는 뜻" },
    { "id": "ko-hard-005", "text": "낮말은 새가 듣고 밤말은 쥐가 듣는다", "type": "proverb", "meaning": "아무도 없는 곳에서도 말을 조심해야 한다는 뜻" },
    { "id": "ko-hard-006", "text": "시작이 반이다", "type": "proverb", "meaning": "어떤 일이든 시작하는 것이 가장 중요하다는 뜻" },
    { "id": "ko-hard-007", "text": "천 리 길도 한 걸음부터", "type": "proverb", "meaning": "아무리 먼 길도 첫 발을 내딛는 것부터 시작된다는 뜻" },
    { "id": "ko-hard-008", "text": "콩 심은 데 콩 나고 팥 심은 데 팥 난다", "type": "proverb", "meaning": "원인에 따라 결과가 달라진다는 뜻" },
    { "id": "ko-hard-009", "text": "아는 길도 물어 가라", "type": "proverb", "meaning": "잘 안다고 자만하지 말고 항상 확인하고 조심하라는 뜻" },
    { "id": "ko-hard-010", "text": "배보다 배꼽이 더 크다", "type": "proverb", "meaning": "기본보다 부속이 더 커지는 어이없는 상황을 비유한 말" },
    { "id": "ko-hard-011", "text": "백지장도 맞들면 낫다", "type": "proverb", "meaning": "아무리 쉬운 일도 혼자보다 함께하면 더 잘된다는 뜻" },
    { "id": "ko-hard-012", "text": "빈 수레가 요란하다", "type": "proverb", "meaning": "실속 없는 사람이 오히려 더 시끄럽게 떠든다는 뜻" },
    { "id": "ko-hard-013", "text": "우물 안 개구리", "type": "proverb", "meaning": "넓은 세상을 모르고 좁은 세계에 갇혀 있는 사람을 비유한 말" },
    { "id": "ko-hard-014", "text": "티끌 모아 태산", "type": "proverb", "meaning": "작은 것도 차곡차곡 모으면 나중에 크게 된다는 뜻" },
    { "id": "ko-hard-015", "text": "등잔 밑이 어둡다", "type": "proverb", "meaning": "가까이 있는 것을 오히려 잘 모르는 경우를 이르는 말" },
    { "id": "ko-hard-016", "text": "모로 가도 서울만 가면 된다", "type": "proverb", "meaning": "방법이 어떻든 목적만 이루면 된다는 뜻" },
    { "id": "ko-hard-017", "text": "원숭이도 나무에서 떨어진다", "type": "proverb", "meaning": "아무리 능숙한 사람도 실수할 수 있다는 뜻" },
    { "id": "ko-hard-018", "text": "고생 끝에 낙이 온다", "type": "proverb", "meaning": "힘든 시련을 참고 이겨내면 좋은 일이 생긴다는 뜻" },
    { "id": "ko-hard-019", "text": "말 한마디에 천 냥 빚도 갚는다", "type": "proverb", "meaning": "말을 잘하면 어떤 어려운 일도 해결할 수 있다는 뜻" },
    { "id": "ko-hard-020", "text": "쇠뿔도 단김에 빼라", "type": "proverb", "meaning": "일을 할 때는 적당한 기회를 잡아 단번에 해결하라는 뜻" },
    { "id": "ko-hard-021", "text": "지렁이도 밟으면 꿈틀한다", "type": "proverb", "meaning": "아무리 순한 사람도 지나치게 괴롭히면 반발한다는 뜻" },
    { "id": "ko-hard-022", "text": "하늘은 스스로 돕는 자를 돕는다", "type": "proverb", "meaning": "자신이 먼저 노력해야 남의 도움도 받을 수 있다는 뜻" },
    { "id": "ko-hard-023", "text": "윗물이 맑아야 아랫물이 맑다", "type": "proverb", "meaning": "윗사람이 바르게 행동해야 아랫사람도 그것을 본받는다는 뜻" },
    { "id": "ko-hard-024", "text": "가랑비에 옷 젖는 줄 모른다", "type": "proverb", "meaning": "작은 것이라도 자꾸 계속되면 결국 크게 영향을 미친다는 뜻" },
    { "id": "ko-hard-025", "text": "돌다리도 두드려 보고 건너라", "type": "proverb", "meaning": "안전해 보여도 꼼꼼히 확인하고 신중하게 행동하라는 뜻" },
    { "id": "ko-hard-026", "text": "금강산도 식후경", "type": "proverb", "meaning": "아무리 좋은 것도 배가 불러야 제대로 즐길 수 있다는 뜻" },
    { "id": "ko-hard-027", "text": "개천에서 용 난다", "type": "proverb", "meaning": "변변치 않은 환경에서 뛰어난 인물이 나온다는 뜻" },
    { "id": "ko-hard-028", "text": "사공이 많으면 배가 산으로 간다", "type": "proverb", "meaning": "주관하는 사람이 너무 많으면 일이 엉뚱한 방향으로 흐른다는 뜻" },
    { "id": "ko-hard-029", "text": "가는 날이 장날이다", "type": "proverb", "meaning": "뜻하지 않게 어떤 일과 때가 맞아 떨어지는 경우를 이르는 말" },
    { "id": "ko-hard-030", "text": "뜻이 있는 곳에 길이 있다", "type": "proverb", "meaning": "확고한 의지가 있으면 반드시 방법을 찾을 수 있다는 뜻" },
    { "id": "ko-hard-031", "text": "오르지 못할 나무는 쳐다보지도 마라", "type": "proverb", "meaning": "자신의 능력 밖의 일에 욕심을 내지 말라는 뜻" },
    { "id": "ko-hard-032", "text": "남의 떡이 더 커 보인다", "type": "proverb", "meaning": "자기 것보다 남의 것이 더 좋아 보이는 심리를 이르는 말" },
    { "id": "ko-hard-033", "text": "공든 탑이 무너지랴", "type": "proverb", "meaning": "정성껏 이루어 놓은 일은 쉽게 무너지지 않는다는 뜻" },
    { "id": "ko-hard-034", "text": "누울 자리 봐 가며 발을 뻗어라", "type": "proverb", "meaning": "어떤 일이든 상황을 먼저 파악하고 행동하라는 뜻" },
    { "id": "ko-hard-035", "text": "열 번 찍어 아니 넘어가는 나무 없다", "type": "proverb", "meaning": "꾸준히 노력하면 아무리 어려운 일도 이룰 수 있다는 뜻" },
    { "id": "ko-hard-036", "text": "친구 따라 강남 간다", "type": "proverb", "meaning": "자신의 뚜렷한 의지 없이 남을 무작정 따라 행동하는 것을 이르는 말" },
    { "id": "ko-hard-037", "text": "소 잃고 외양간 고친다", "type": "proverb", "meaning": "일이 잘못된 뒤에야 뒤늦게 수습하려 한다는 뜻" },
    { "id": "ko-hard-038", "text": "못 먹는 감 찔러나 본다", "type": "proverb", "meaning": "자신이 가질 수 없는 것이면 남도 못 갖게 훼방을 놓는다는 뜻" },
    { "id": "ko-hard-039", "text": "세월이 약이다", "type": "proverb", "meaning": "시간이 지나면 아무리 큰 슬픔도 결국 나아진다는 뜻" },
    { "id": "ko-hard-040", "text": "될성부른 나무는 떡잎부터 알아본다", "type": "proverb", "meaning": "크게 될 사람은 어릴 때부터 남다른 면이 보인다는 뜻" },
    { "id": "ko-hard-041", "text": "물이 너무 맑으면 고기가 없다", "type": "proverb", "meaning": "너무 엄격하고 완벽하면 오히려 주변에 사람이 없어진다는 뜻" },
    { "id": "ko-hard-042", "text": "자라 보고 놀란 가슴 솥뚜껑 보고 놀란다", "type": "proverb", "meaning": "한 번 크게 놀란 경험이 있으면 비슷한 것에도 겁을 낸다는 뜻" },
    { "id": "ko-hard-043", "text": "입은 삐뚤어져도 말은 바로 해라", "type": "proverb", "meaning": "어떤 상황에서도 말만큼은 정직하고 바르게 해야 한다는 뜻" },
    { "id": "ko-hard-044", "text": "구슬이 서 말이라도 꿰어야 보배", "type": "proverb", "meaning": "아무리 좋은 것이라도 쓸모 있게 활용해야 가치가 있다는 뜻" },
    { "id": "ko-hard-045", "text": "제 눈에 안경이다", "type": "proverb", "meaning": "자기 마음에 드는 것은 무엇이나 좋아 보인다는 뜻" },
    { "id": "ko-hard-046", "text": "소문난 잔치에 먹을 것 없다", "type": "proverb", "meaning": "크게 소문난 것치고는 막상 실속이 없다는 뜻" },
    { "id": "ko-hard-047", "text": "아니 땐 굴뚝에 연기 나랴", "type": "proverb", "meaning": "원인이 없으면 결과도 없다, 소문에는 반드시 근거가 있다는 뜻" },
    { "id": "ko-hard-048", "text": "바늘 도둑이 소도둑 된다", "type": "proverb", "meaning": "작은 나쁜 일도 계속하면 점점 큰 나쁜 일로 이어진다는 뜻" },
    { "id": "ko-hard-049", "text": "고양이한테 생선을 맡긴다", "type": "proverb", "meaning": "믿기 어려운 사람에게 중요한 일을 맡기는 어리석음을 이르는 말" },
    { "id": "ko-hard-050", "text": "하나를 보면 열을 안다", "type": "proverb", "meaning": "한 가지 행동을 보면 그 사람의 전체를 파악할 수 있다는 뜻" },
    { "id": "ko-hard-051", "text": "넘어져도 괜찮아 다시 일어나면 돼", "type": "quote", "meaning": "실패해도 포기하지 않고 다시 도전하면 된다는 뜻" },
    { "id": "ko-hard-052", "text": "인생은 짧고 예술은 길다", "type": "quote", "meaning": "사람의 삶은 짧지만 그가 남긴 작품과 업적은 오래 남는다는 뜻" },
    { "id": "ko-hard-053", "text": "지식은 힘이다", "type": "quote", "meaning": "알고 배우는 것이 삶을 이끌어가는 강력한 도구라는 뜻" },
    { "id": "ko-hard-054", "text": "행동하지 않는 꿈은 그냥 꿈일 뿐이다", "type": "quote", "meaning": "꿈을 이루려면 실제로 행동해야 한다는 뜻" },
    { "id": "ko-hard-055", "text": "천재는 노력하는 자를 이길 수 없다", "type": "quote", "meaning": "타고난 재능보다 꾸준한 노력이 더 큰 결과를 만든다는 뜻" },
    { "id": "ko-hard-056", "text": "변화를 두려워하지 않는 자가 세상을 이긴다", "type": "quote", "meaning": "새로운 도전을 받아들이는 사람이 결국 성공한다는 뜻" },
    { "id": "ko-hard-057", "text": "오늘 할 수 있는 일을 내일로 미루지 마라", "type": "quote", "meaning": "해야 할 일은 지금 당장 실천하라는 뜻" },
    { "id": "ko-hard-058", "text": "실패는 성공의 어머니다", "type": "quote", "meaning": "실패 경험이 쌓여 결국 성공으로 이어진다는 뜻" },
    { "id": "ko-hard-059", "text": "할 수 있다고 믿는 자가 할 수 있다", "type": "quote", "meaning": "자신의 가능성을 믿는 긍정적 태도가 성공을 부른다는 뜻" },
    { "id": "ko-hard-060", "text": "독서는 마음의 양식이다", "type": "quote", "meaning": "책을 읽는 것은 마음과 지식을 풍요롭게 하는 일이라는 뜻" },
    { "id": "ko-hard-061", "text": "함께라면 불가능도 가능해진다", "type": "quote", "meaning": "서로 협력하면 혼자서는 못할 일도 이룰 수 있다는 뜻" },
    { "id": "ko-hard-062", "text": "지금 이 순간이 가장 소중하다", "type": "quote", "meaning": "과거나 미래보다 현재에 최선을 다하는 것이 중요하다는 뜻" },
    { "id": "ko-hard-063", "text": "작은 것에 감사할 줄 아는 사람이 행복하다", "type": "quote", "meaning": "사소한 것에서도 고마움을 느끼는 사람이 진정 행복하다는 뜻" },
    { "id": "ko-hard-064", "text": "어제보다 나은 오늘을 만들자", "type": "quote", "meaning": "매일 조금씩 성장하고 발전하는 삶을 살자는 뜻" },
    { "id": "ko-hard-065", "text": "포기란 없다 방법을 찾아라", "type": "quote", "meaning": "어려운 상황에서도 해결책을 찾으려는 의지를 가지라는 뜻" },
    { "id": "ko-hard-066", "text": "남을 이기기 전에 자신을 먼저 이겨라", "type": "quote", "meaning": "진정한 경쟁은 타인이 아닌 자기 자신과 하는 것이라는 뜻" },
    { "id": "ko-hard-067", "text": "좋은 습관이 좋은 인생을 만든다", "type": "quote", "meaning": "매일의 작은 습관들이 쌓여 삶의 방향을 결정한다는 뜻" },
    { "id": "ko-hard-068", "text": "두드리면 열린다", "type": "quote", "meaning": "끊임없이 노력하고 도전하면 결국 원하는 것을 얻는다는 뜻" },
    { "id": "ko-hard-069", "text": "위대한 일은 작은 일들의 모임이다", "type": "quote", "meaning": "작고 평범한 일들이 쌓여 결국 위대한 결과를 만든다는 뜻" },
    { "id": "ko-hard-070", "text": "나는 생각한다 고로 나는 존재한다", "type": "quote", "meaning": "생각하는 능력이 곧 인간 존재의 증거라는 철학적 명언" },
    { "id": "ko-hard-071", "text": "용기 있는 자만이 진정한 자유를 누린다", "type": "quote", "meaning": "두려움을 극복하는 자만이 진정한 삶의 자유를 얻는다는 뜻" },
    { "id": "ko-hard-072", "text": "배우고 익히면 또한 기쁘지 아니한가", "type": "quote", "meaning": "배움을 실천하는 즐거움이야말로 진정한 기쁨이라는 공자의 말" },
    { "id": "ko-hard-073", "text": "가장 빠른 길은 올바른 방향으로 가는 것", "type": "quote", "meaning": "방향이 맞아야 빠르게 목표에 도달할 수 있다는 뜻" },
    { "id": "ko-hard-074", "text": "모든 것은 마음먹기에 달려 있다", "type": "quote", "meaning": "어떤 상황도 자신의 마음가짐에 따라 달라진다는 뜻" },
    { "id": "ko-hard-075", "text": "씨앗을 심지 않으면 꽃을 볼 수 없다", "type": "quote", "meaning": "미리 준비하고 노력해야만 좋은 결과를 얻을 수 있다는 뜻" },
    { "id": "ko-hard-076", "text": "겸손한 자가 결국 높아진다", "type": "quote", "meaning": "자신을 낮추고 겸손하게 행동하는 사람이 오래 존경받는다는 뜻" },
    { "id": "ko-hard-077", "text": "뜨거운 가슴과 차가운 머리가 필요하다", "type": "quote", "meaning": "열정과 냉철한 이성을 함께 갖추어야 현명하게 행동할 수 있다는 뜻" },
    { "id": "ko-hard-078", "text": "한 권의 책은 천 명의 스승이다", "type": "quote", "meaning": "좋은 책 한 권이 수많은 가르침을 담고 있다는 뜻" },
    { "id": "ko-hard-079", "text": "강한 자가 살아남는 게 아니라 살아남는 자가 강한 것이다", "type": "quote", "meaning": "끝까지 포기하지 않고 버텨내는 사람이 결국 강한 사람이라는 뜻" },
    { "id": "ko-hard-080", "text": "네 꿈을 살아라 다른 사람의 삶을 살지 말고", "type": "quote", "meaning": "남의 기대나 시선이 아닌 자신이 원하는 삶을 살라는 뜻" }
  ]
}
